{
  "name": "japan-job-agent",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:verify": "tsx packages/db/src/verify-migrations.ts",
    "live:audit": "pnpm live:audit:greenhouse && pnpm live:audit:schema",
    "live:audit:greenhouse": "tsx scripts/audit-greenhouse-tenants.ts",
    "live:audit:schema": "tsx scripts/audit-schema-org-jobs.ts",
    "source:seed-verified": "tsx scripts/seed-verified-greenhouse.ts",
    "sync:greenhouse": "tsx scripts/sync-greenhouse.ts",
    "sync:schema": "tsx scripts/sync-schema-org.ts",
    "extract:pending": "tsx scripts/extract-pending.ts",
    "dev:api": "tsx watch apps/api/src/main.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1085.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "cheerio": "1.2.0",
    "fastify": "5.10.0",
    "kysely": "0.29.3",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/pg": "8.20.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
