{
  "name": "japan-job-agent",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc -b",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx packages/db/src/migrate.ts",
    "db:verify": "tsx packages/db/src/verify-migrations.ts",
    "live:audit": "pnpm live:audit:greenhouse && pnpm live:audit:schema",
    "live:audit:greenhouse": "tsx scripts/audit-greenhouse-tenants.ts",
    "live:audit:schema": "tsx scripts/audit-schema-org-jobs.ts",
    "source:seed-verified": "tsx scripts/seed-verified-greenhouse.ts",
    "source:seed-company-audits": "tsx scripts/seed-company-audits.ts",
    "sync:greenhouse": "tsx scripts/sync-greenhouse.ts",
    "sync:hrmos": "tsx scripts/sync-hrmos.ts",
    "discovery:jetro-ofp": "tsx scripts/import-jetro-ofp.ts",
    "discovery:audit-details": "tsx scripts/audit-jetro-ofp-details.ts",
    "discovery:audit-entrypoints": "tsx scripts/audit-recruitment-entrypoints.ts",
    "discovery:audit-candidates": "tsx scripts/audit-recruitment-candidates.ts",
    "discovery:promote": "tsx scripts/promote-jetro-companies.ts",
    "discovery:report": "tsx scripts/export-promotion-report.ts",
    "corpus:report": "tsx scripts/export-corpus-report.ts",
    "sync:schema": "tsx scripts/sync-schema-org.ts",
    "extract:pending": "tsx scripts/extract-pending.ts",
    "canonical:materialize": "tsx scripts/materialize-canonical.ts",
    "profile:import-safe": "tsx scripts/import-safe-profile.ts",
    "dev:api": "tsx watch apps/api/src/main.ts",
    "dev:web": "pnpm --filter @jja/web dev",
    "build:web": "pnpm --filter @jja/web build",
    "worker:start": "tsx packages/worker/src/main.ts",
    "temporal:schedules": "tsx scripts/ensure-temporal-schedules.ts",
    "temporal:refresh-source": "tsx scripts/start-source-workflow.ts",
    "backup:database": "tsx scripts/backup-database.ts",
    "backup:restore-verify": "tsx scripts/verify-backup-restore.ts",
    "acceptance:verify": "tsx scripts/verify-final-acceptance.ts",
    "deploy:preflight": "tsx scripts/verify-production-config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1085.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "@temporalio/activity": "1.20.2",
    "@temporalio/client": "1.20.2",
    "@temporalio/worker": "1.20.2",
    "@temporalio/workflow": "1.20.2",
    "cheerio": "1.2.0",
    "fastify": "5.10.0",
    "kysely": "0.29.3",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/pg": "8.20.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
