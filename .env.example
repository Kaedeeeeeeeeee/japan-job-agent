DATABASE_URL=postgresql://postgres:postgres@localhost:5432/japan_job_agent
RAW_STORAGE_PATH=.data
DEPLOYMENT_TARGET=linux

# Production private S3-compatible storage
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Temporal private service
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=japan-job-agent
WORKER_ACTIVITY_CONCURRENCY=2
DISCOVERY_BACKFILL_DAYS=30
ENGAGE_DISCOVERY_MODE=active
ENGAGE_SITEMAP_MAX_FILES_PER_RUN=10000
SOURCE_EXPANSION_ENABLED=false
SOURCE_EXPANSION_WORKERS=4
SOURCE_EXPANSION_HOST_INTERVAL_MS=1000
SOURCE_EXPANSION_TENANT_TIMEOUT_MS=120000

# Optional single-provider AI pipeline (OpenAI-compatible HTTP API)
AI_ENRICHMENT_ENABLED=false
SEMANTIC_RETRIEVAL_ENABLED=false
AI_EXPLANATIONS_ENABLED=false
AI_PROVIDER_KEY=openai-compatible
AI_BASE_URL=
AI_API_KEY=
AI_EXTRACTION_MODEL=
AI_EMBEDDING_MODEL=
AI_EXPLANATION_MODEL=
AI_TIMEOUT_MS=30000
AI_CONCURRENCY=2
AI_DAILY_TOKEN_BUDGET=1000000

# Private Web/API
API_BASE_URL=http://127.0.0.1:3001
# Shared only by the private Web server and API; generate with `openssl rand -hex 32`.
API_INTERNAL_TOKEN=
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ALLOWED_GITHUB_LOGIN=Kaedeeeeeeeeee
# Explicit local development only; ignored in production
AUTH_BYPASS_LOCAL=false

# Weekly logical backups
BACKUP_BUCKET=
BACKUP_OUTPUT_PATH=
BACKUP_INPUT_PATH=
RESTORE_DATABASE_URL=
PG_DUMP_BIN=pg_dump
PG_RESTORE_BIN=pg_restore
