{
  "$schema": "https://railway.com/railway.schema.json",
  "build": { "builder": "DOCKERFILE", "dockerfilePath": "/deploy/docker/Dockerfile.api" },
  "deploy": { "preDeployCommand": ["pnpm db:migrate"], "healthcheckPath": "/health", "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE", "restartPolicyMaxRetries": 5 }
}
