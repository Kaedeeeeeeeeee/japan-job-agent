{
  "$schema": "https://railway.com/railway.schema.json",
  "build": { "builder": "DOCKERFILE", "dockerfilePath": "/deploy/docker/Dockerfile.worker" },
  "deploy": {
    "startCommand": "pnpm backup:database",
    "cronSchedule": "43 18 * * 0",
    "multiRegionConfig": { "asia-southeast1-eqsg3a": { "numReplicas": 1 } },
    "restartPolicyType": "NEVER"
  }
}
