{
  "$schema": "https://railway.com/railway.schema.json",
  "build": { "builder": "DOCKERFILE", "dockerfilePath": "/deploy/docker/Dockerfile.web" },
  "deploy": { "healthcheckPath": "/signin", "healthcheckTimeout": 120,
    "multiRegionConfig": { "asia-southeast1-eqsg3a": { "numReplicas": 1 } },
    "restartPolicyType": "ON_FAILURE", "restartPolicyMaxRetries": 5 }
}
