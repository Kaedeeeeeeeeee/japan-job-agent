POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=japan_job_agent
JJA_DATA_ROOT=/srv/japan-job-agent

# Output of `tailscale ip -4`; 127.0.0.1 keeps the service host-local.
TAILSCALE_BIND_IP=100.64.0.1
WEB_PORT=3000
API_PORT=3001
AUTH_URL=https://japan-job-agent.example-tailnet.ts.net

API_INTERNAL_TOKEN=replace-with-at-least-32-random-characters
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_GITHUB_ID=company-owned-github-oauth-client-id
AUTH_GITHUB_SECRET=company-owned-github-oauth-client-secret
