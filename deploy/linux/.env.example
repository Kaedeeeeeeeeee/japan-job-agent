POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=japan_job_agent
JJA_DATA_ROOT=/srv/japan-job-agent

# Private Cloudflare R2 backup bucket. The application encrypts every database
# dump before upload; use an Object Read & Write token scoped to this bucket.
BACKUP_BUCKET=jja-encrypted-backups
S3_ENDPOINT=https://replace-with-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=replace-with-bucket-scoped-r2-access-key
AWS_SECRET_ACCESS_KEY=replace-with-bucket-scoped-r2-secret-key
BACKUP_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32-output

# Output of `tailscale ip -4`; 127.0.0.1 keeps the service host-local.
TAILSCALE_BIND_IP=100.64.0.1
WEB_PORT=3000
API_PORT=3001
AUTH_URL=https://japan-job-agent.example-tailnet.ts.net

API_INTERNAL_TOKEN=replace-with-at-least-32-random-characters
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_GITHUB_ID=company-owned-github-oauth-client-id
AUTH_GITHUB_SECRET=company-owned-github-oauth-client-secret

# Freshness-first source expansion (disabled until backup, migration, and artifact dry-run).
DISCOVERY_BACKFILL_DAYS=30
ENGAGE_DISCOVERY_MODE=active
ENGAGE_SITEMAP_MAX_FILES_PER_RUN=10000
SOURCE_EXPANSION_ENABLED=false
SOURCE_EXPANSION_WORKERS=4
SOURCE_EXPANSION_HOST_INTERVAL_MS=1000
SOURCE_EXPANSION_TENANT_TIMEOUT_MS=120000
